#!/bin/env python3

"""CLI to control CAX mirror motors for scanning its mirror."""

# from datetime import datetime
# import time
import numpy as np
import matplotlib.pyplot as plt
from caxscripts import utils

from siriuspy.devices import CAXCtrl
# from motorkin import M1Kinematics
from caxscripts.motormov import (
    DeviceMove, CAXMirrorMove, CAXCausticMove, CAXSlitMove, SCAN_TYPES
    )

PV_SCAN_TYPES = {
    '1': 'tx',
    '2': 'cs_rx',
    '3': 'cs_ty',
    '4': 'ry',
    '5': 'cs_rz',
    '6': 'pos_z',
    '7': 'lens_pos',
    '8': 'slit_A1',
    '9': 'slit_B1',
}


def scan_menu_select():
    """Select scan type from a menu."""
    print("\nSelect scan (type a list of numbers separated by spaces):\n")
    for key, value in SCAN_TYPES.items():
        print(f"  {key} - {value} scan")

    caxdevs = list()
    choices = input("\n Enter choice [1-9], 'q' to quit: ")

    # Quit
    if choices.lower() == 'q':
        print("Exiting... Done.")
        exit(0)

    # Validate choices and create corresponding device move instances.
    choices = choices.strip().split()
    for choice in choices:
        try:
            if choice not in SCAN_TYPES:
                raise ValueError("Invalid choice")
            # Type of scan.
            if choice in list(map(str, range(1, 6))):
                caxdev = CAXMirrorMove()
            elif choice in ['6', '7']:
                caxdev = CAXCausticMove()
            else:
                caxdev = CAXSlitMove()
            caxdevs.append(caxdev)
        except Exception as err:
            print(f"{err} -- '{choice}' "
                " Please enter a number between 1 and 9.")
            scan_menu_select()  # Restart menu selection

    # DEBUG
    print("\n#####\n##### [DEBUG] Scan Menu Select "
          f"\n##### User choices: {choices},"
          f"\n##### CAX devices to scan:\n {caxdevs}\n#####\n\n")
    # END DEBUG

    return list(set(choices)), list(set(caxdevs))


def status_show(cax):
    """Show current status of the device."""
    # Get current status of all devices.
    status = utils.current_config(cax)

    # DEBUG: Show raw status dictionary
    print("\n#####\n##### [DEBUG] Current Status Dictionary:\n")
    for key, val in status.items():
        print(f"{key}: {val}\n")
    print("#####\n\n") 
    # END DEBUG

    # Run through all devices and print their status.
    for key, val in status.items():
        print(f" -- {key.replace('_', ' ').title()}:\n")
        try:
            for pv, vs in val.items():
                print(f"    * {pv:15} : {vs:10.4f}")

                # print(f"  * {pv:12} : ", end="")
                # enbl = True if vs[1] == 1 else False
                # print(f"{vs[0]:12.6f}, enabled = {enbl}")
            print("\n")
        except Exception:
            for bl, v in val:
                print(f"  * {bl:15} : {v:10.4f}")
    print("\n#####\n")


def parameters_ask(scantype: str, caxdev):
    """Get scan parameters from user."""
    # Parameter limits.
    print("\n\n** Parameter limits:")
    print()

    st = SCAN_TYPES[scantype]
    scanset = dict()
    print(f"###\n###  {st} scan parameters\n###\n")
    scanset['start']  = float(input(
        f"Enter start {st} position/angle: "
        ))
    scanset['stop']   = float(input(
        f"Enter stop {st} position/angle: "
        ))
    scanset['nsteps'] = float(input(
        "Enter number of steps for scanning: "
        ))
    scanset['dtime']  = float(input(
        "Enter dwell time at each position (seconds): "
        ))
    return scanset


def show_results(results, scantype: str):
    """Show scan results."""
    print("\n\n##### Scan Results #####\n")
    fig, ax = plt.subplots()
    ax.plot(results['position'], results['intensity'], marker='o')
    ax.set_xlabel('Position/Angle (urad)')
    ax.set_ylabel('Intensity (a.u.)')
    dt = SCAN_TYPES[scantype]
    ax.set_title(f'CAX {dt} Scan Results')
    plt.grid()
    plt.show()


def main():
    """Main function to run the CLI."""
    # DEBUG: Verify module origin
    # import siriuspy.devices.beamlines.mirror as mirror
    # print(f"\n[DEBUG] Mirror module loaded from: {mirror.__file__}\n")
    # END DEBUG

    # Initialize control.
    cax = CAXCtrl()

    # Show status of devices.
    status_show(cax)

    # Current status.
    print("\n\n#####\n##### Carcará Scanning System\n#####\n")
    # motor_positions(caxmov)

    # Select scan type.
    scantype, caxdevs = scan_menu_select()

    # DEBUG: Show status of each device.
    # print(f"\n SCAN TYPES = {SCAN_TYPES}\n caxdevs = {caxdevs}\n\n",
    #       flush=True)
    # END DEBUG

    # Show first current status of selected devices.
    print("\n\n\n##### Current Status of Selected Devices #####\n\n")

    # DEBUG
    print("\n#####"
          f"\n##### [DEBUG] scantype = {scantype},"
          f"\n##### [DEBUG] caxdevs  = {caxdevs}\n#####\n\n")
    # DEBUG

    for st, caxdev in zip(scantype, caxdevs):  # noqa: B905
        scanset = parameters_ask(st, caxdev)
        results = DeviceMove.device_scan(st, caxdev, scanset)
    return

    # Show and/or record results.
    if results is not None:
        show_results(results, scantype)
        recres = input(" Do you want to save the results to a file? (y/n): ")
        if recres.lower() == 'y':
            filename = input(" Enter filename to save results"
                             " (e.g., scan_results.npz): ")
            np.savez(filename, **results)
            print(f" Results saved to {filename}.")
    else:
        print(" No results to show.")


if __name__ == "__main__":
    """."""
    main()
